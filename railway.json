{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "*.py",
      "Dockerfile",
      "requirements.txt",
      "railway.json",
      ".env.example",
      ".gitattributes"
    ]
  },
  "deploy": {
    "startCommand": "python -u bot.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
