# PRIDE Operations — env variables example

# Telegram Bot (for Login Widget verify)
TG_BOT_TOKEN=
TG_BOT_USERNAME=PrideInviteWork_bot

# JARVIS integration
JARVIS_BASE_URL=https://workchat-bot-production.up.railway.app
JARVIS_API_TOKEN=

# P2P integration
P2P_BASE_URL=https://pride-p2p-production.up.railway.app

# Auth
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-USE-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# Database (Railway auto-injects)
DATABASE_URL=

# Redis (Railway auto-injects)
REDIS_URL=

# Admin TG user IDs (comma-separated)
ADMIN_TG_IDS=8151738775

# Feature flags
FEATURE_CABINET_ENABLED=true
FEATURE_ADMIN_ENABLED=false
