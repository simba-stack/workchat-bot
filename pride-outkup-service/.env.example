# Bot
BOT_TOKEN=
BOT_USERNAME=PrideP2P_bot

# Mini-App
MINIAPP_URL=https://pride-outkup-service-production.up.railway.app
MINIAPP_PATH=/app

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pride_outkup
# Railway auto-fills: postgresql://... → конвертируем в asyncpg в core/db.py

# Redis (опционально, для rate-limit и pub/sub)
REDIS_URL=

# JARVIS sync (webhook + REST)
JARVIS_BASE_URL=https://workchat-bot-production.up.railway.app
JARVIS_WEBHOOK_PATH=/api/webhook/outkup
JARVIS_HMAC_SECRET=
JARVIS_API_TOKEN=

# TRON / USDT TRC20
TRON_PRIVATE_KEY=
TRON_HOT_WALLET_ADDRESS=
TRONGRID_API_KEY=
TRON_NETWORK=mainnet

# Admin
ADMIN_TG_IDS=8151738775

# Rate limits / лимиты
MAX_CONCURRENT_DEALS_PER_USER=5
KYC_LVL1_DAILY_LIMIT_USDT=500
KYC_LVL2_DAILY_LIMIT_USDT=5000
KYC_LVL3_DAILY_LIMIT_USDT=50000

# Maintenance / feature flags
FEATURE_V2_P2P_ENABLED=false
FEATURE_REFERRAL_ENABLED=true
