--
-- Структура таблицы `Drops`
--

CREATE TABLE `Drops` (
  `id` int NOT NULL,
  `chatId` bigint DEFAULT NULL,
  `ownerId` int DEFAULT NULL,
  `fio` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `scan` json DEFAULT NULL,
  `about` text COLLATE utf8mb4_unicode_ci,
  `price` int NOT NULL DEFAULT '0',
  `buydate` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `deal` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `prolit` int NOT NULL DEFAULT '0',
  `send` tinyint(1) NOT NULL DEFAULT '0',
  `accept` int NOT NULL DEFAULT '0',
  `ready` int NOT NULL DEFAULT '0',
  `link_access` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `msgid` int DEFAULT NULL,
  `msgid_otr` int DEFAULT NULL,
  `createdAt` datetime NOT NULL,
  `updatedAt` datetime NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

