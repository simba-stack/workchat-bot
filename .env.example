# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Данные userbot-аккаунта с https://my.telegram.org/apps
API_ID=12345
API_HASH=0123456789abcdef0123456789abcdef

# Номер телефона userbot-аккаунта (с международным кодом, без пробелов)
USERBOT_PHONE=+71234567890

# Telegram ID администратора (вас) - чтобы только вы могли управлять списком работников
# Узнать свой ID можно у бота @userinfobot
ADMIN_ID=123456789

# String-сессия userbot (генерируется один раз через generate_session.py).
# Локально оставьте пустым — будет использоваться файл-сессия.
# Для деплоя на Railway/cloud — обязательно вставьте сюда сгенерированную строку.
STRING_SESSION=
